# Required: create an API token in your own e-Boekhouden administration.
EBOEKHOUDEN_MCP_SECRET_TOKEN=replace-with-your-own-token

# Safety defaults. Write tools are not exposed unless explicitly enabled.
EBOEKHOUDEN_MCP_ENABLE_WRITE_TOOLS=false
# EBOEKHOUDEN_MCP_LOG_LEVEL=WARNING

# Optional digital archive integration. This is a separate, opt-in write capability.
EBOEKHOUDEN_MCP_ENABLE_ARCHIVE_TOOL=false
# EBOEKHOUDEN_MCP_ARCHIVE_ROOT=/absolute/path/to/allowed/invoices
# EBOEKHOUDEN_ARCHIVE_EMAIL=your-archive-address@e-Boekhouden.nl
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_SEND_FROM_USER=

# Advanced: the official API endpoint is enforced unless the explicit override is enabled.
# EBOEKHOUDEN_MCP_API_URL=https://api.e-boekhouden.nl/
# EBOEKHOUDEN_MCP_ALLOW_CUSTOM_API_URL=false
